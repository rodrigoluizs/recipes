---
import { Icon } from 'astro-icon/components';
import type { Ingredient } from '../lib/types';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  ingredients: Ingredient[];
  servings: number;
  locale: Locale;
}

const { ingredients, servings, locale } = Astro.props;
const s = t(locale);
// Only ingredients with a numeric amount can be used as a scaling basis.
const scalable = ingredients.filter((i) => i.amount !== undefined);
---

<div class="scale-panel" id="scale-panel" hidden>
  <div class="segmented" role="tablist" aria-label={s.scalingModeAriaLabel}>
    <button type="button" role="tab" class="seg is-active" data-scale-mode="amount">{s.modeAmount}</button>
    <button type="button" role="tab" class="seg" data-scale-mode="serving">{s.modeServing}</button>
    {scalable.length > 0 && (
      <button type="button" role="tab" class="seg" data-scale-mode="ingredient">{s.modeIngredient}</button>
    )}
  </div>

  <div class="row">
    <div class="slider-wrap">
      <input
        id="scale-slider"
        type="range"
        min="0.25"
        max="8"
        step="0.25"
        value="1"
        data-base-servings={servings}
        aria-label={s.scaleAriaLabel}
      />
    </div>

    <!-- ingredient mode: pick which ingredient to scale by -->
    <button type="button" class="select-btn" id="scale-select" hidden>
      <Icon name="lucide:carrot" size={18} />
      <span id="scale-select-label">{s.select}</span>
    </button>

    <!-- editable value (type instead of / alongside the slider) -->
    <div class="value-box" id="scale-value-box">
      <span class="affix" id="scale-prefix">×</span>
      <input
        id="scale-value"
        type="number"
        min="0"
        step="any"
        inputmode="decimal"
        value="1"
        aria-label={s.scaleValueAriaLabel}
      />
      <span class="affix suffix" id="scale-suffix"></span>
    </div>
  </div>

  <p class="hint" id="scale-hint" hidden>{s.scaleHint}</p>

  <button type="button" class="reset" data-scale-reset>{s.resetToOriginal}</button>
</div>

<style>
  .scale-panel {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 16px;
    margin: 8px 0 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .scale-panel[hidden] {
    display: none;
  }

  .segmented {
    display: flex;
    background: var(--surface-2);
    border-radius: 12px;
    padding: 4px;
    gap: 4px;
  }
  .seg {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--fg);
    padding: 10px 8px;
    border-radius: 9px;
    font-size: 1rem;
    font-weight: 600;
  }
  .seg.is-active {
    background: #55555a;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .slider-wrap {
    flex: 1;
    min-width: 0;
  }

  input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 12px;
    border-radius: var(--radius-pill);
    background:
      linear-gradient(var(--accent) 0 0) no-repeat,
      var(--surface-2);
    background-size: var(--fill, 12%) 100%;
    cursor: pointer;
  }
  input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
  }
  input[type='range']::-moz-range-thumb {
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 50%;
    background: #fff;
  }

  .value-box {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    background: var(--surface-2);
    border-radius: 14px;
    padding: 10px 14px;
    color: var(--accent);
    font-weight: 700;
  }
  .value-box[hidden] {
    display: none;
  }
  .value-box .affix {
    font-size: 1.2rem;
  }
  .value-box .suffix {
    color: var(--muted);
    font-size: 0.95rem;
  }
  #scale-value {
    width: 3.5ch;
    border: 0;
    background: transparent;
    color: var(--accent);
    font: inherit;
    font-size: 1.5rem;
    text-align: center;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  #scale-value::-webkit-outer-spin-button,
  #scale-value::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .select-btn {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0;
    background: var(--surface-2);
    color: var(--muted);
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 1.05rem;
    font-weight: 700;
  }
  .select-btn[hidden] {
    display: none;
  }
  .select-btn.has-selection {
    color: var(--accent);
  }

  .hint {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .hint[hidden] {
    display: none;
  }

  .reset {
    align-self: flex-start;
    border: 0;
    background: none;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0;
  }
</style>
