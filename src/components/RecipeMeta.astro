---
import { totalTime } from '../lib/duration';

interface Props {
  servings: number;
  prepTime: string;
  cookTime: string;
}

const { servings, prepTime, cookTime } = Astro.props;
const total = totalTime(prepTime, cookTime);
---

<div class="meta">
  <div class="pill servings">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"
      ><path
        fill="currentColor"
        d="M16 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm-8 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3Zm0 2c-2.7 0-8 1.34-8 4v2h10v-2c0-.96.7-1.83 1.86-2.5A13.6 13.6 0 0 0 8 13Zm8 0c-.35 0-.74 0-1.16.05C16.17 14 17 15 17 16v2h7v-2c0-2.66-5.3-4-8-4Z"
      ></path></svg
    >
    <span data-servings data-base-servings={servings}>{servings}</span>
  </div>
  <div class="pill times">
    <span class="t">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"
        ><path
          fill="currentColor"
          d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm.5 5H11v6l5.2 3.1.8-1.3-4.5-2.7Z"
        ></path></svg
      >
      <span class="muted">Prep</span> {prepTime}
    </span>
    <span class="sep" aria-hidden="true"></span>
    <span class="t">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"
        ><path
          fill="currentColor"
          d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm.5 5H11v6l5.2 3.1.8-1.3-4.5-2.7Z"
        ></path></svg
      >
      <span class="muted">Cook</span> {cookTime}
    </span>
  </div>
  <div class="pill total" title="Total time">
    <span class="muted">Total</span> {total}
  </div>
</div>

<style>
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 8px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-weight: 600;
  }
  .servings {
    font-size: 1.05rem;
  }
  .times {
    gap: 14px;
  }
  .t {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .times svg {
    opacity: 0.7;
  }
  .sep {
    width: 1px;
    height: 20px;
    background: var(--surface-2);
  }
</style>
