---
import { Icon } from 'astro-icon/components';
import { totalTime } from '../lib/duration';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  servings: number;
  prepTime: string;
  cookTime: string;
  locale: Locale;
}

const { servings, prepTime, cookTime, locale } = Astro.props;
const s = t(locale);
const total = totalTime(prepTime, cookTime, { hr: s.durHr, min: s.durMin });
---

<div class="meta">
  <div class="stat">
    <Icon name="lucide:users" size={20} />
    <span class="val" data-servings data-base-servings={servings}>{servings}</span>
    <span class="lbl">{s.servings}</span>
  </div>
  <div class="stat">
    <Icon name="lucide:clock" size={20} />
    <span class="val">{prepTime}</span>
    <span class="lbl">{s.prep}</span>
  </div>
  <div class="stat">
    <Icon name="lucide:flame" size={20} />
    <span class="val">{cookTime}</span>
    <span class="lbl">{s.cook}</span>
  </div>
  <div class="stat" title={s.totalTitle}>
    <Icon name="lucide:timer" size={20} />
    <span class="val">{total}</span>
    <span class="lbl">{s.total}</span>
  </div>
</div>

<style>
  .meta {
    display: flex;
    align-items: stretch;
    background: var(--surface);
    border-radius: var(--radius);
    margin: 18px 0 8px;
    overflow: hidden;
  }
  .stat {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 4px;
    padding: 14px 8px;
    text-align: center;
  }
  .stat + .stat {
    border-left: 1px solid var(--surface-2);
  }
  .stat svg {
    opacity: 0.7;
    flex-shrink: 0;
  }
  .val {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.2;
    text-wrap: balance;
  }
  .lbl {
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
