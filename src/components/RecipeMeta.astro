---
import { Icon } from 'astro-icon/components';
import { totalTime } from '../lib/duration';

interface Props {
  servings: number;
  prepTime: string;
  cookTime: string;
}

const { servings, prepTime, cookTime } = Astro.props;
const total = totalTime(prepTime, cookTime);
---

<div class="meta">
  <div class="pill servings">
    <Icon name="lucide:users" size={18} />
    <span data-servings data-base-servings={servings}>{servings}</span>
  </div>
  <div class="pill times">
    <span class="t">
      <Icon name="lucide:clock" size={16} />
      <span class="muted">Prep</span> {prepTime}
    </span>
    <span class="sep" aria-hidden="true"></span>
    <span class="t">
      <Icon name="lucide:flame" size={16} />
      <span class="muted">Cook</span> {cookTime}
    </span>
  </div>
  <div class="pill total" title="Total time">
    <span class="muted">Total</span> {total}
  </div>
</div>

<style>
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 8px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-weight: 600;
  }
  .servings {
    font-size: 1.05rem;
  }
  .times {
    gap: 14px;
  }
  .t {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .times svg {
    opacity: 0.7;
  }
  .sep {
    width: 1px;
    height: 20px;
    background: var(--surface-2);
  }
</style>
