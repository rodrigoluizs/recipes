---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { RecipeEntry } from '../lib/recipes';
import { categoryOf } from '../lib/recipes';
import { totalTime } from '../lib/duration';
import { href } from '../lib/url';

interface Props {
  recipe: RecipeEntry;
}

const { recipe } = Astro.props;
const { title, servings, prepTime, cookTime, image, tags } = recipe.data;
const category = categoryOf(recipe.id);
const time = totalTime(prepTime, cookTime);

// Deterministic fallback gradient when there is no photo.
const palettes = [
  ['#3a1c71', '#d76d77'],
  ['#134e5e', '#71b280'],
  ['#42275a', '#734b6d'],
  ['#004e92', '#000428'],
  ['#870000', '#190a05'],
  ['#1f4037', '#99f2c8'],
];
let hash = 0;
for (const ch of recipe.id) hash = (hash * 31 + ch.charCodeAt(0)) >>> 0;
const [c1, c2] = palettes[hash % palettes.length];

// Lowercased haystacks for client-side search filtering.
const searchTitle = title.toLowerCase();
const searchTags = tags.join(' ').toLowerCase();
const searchIngredients = recipe.data.ingredients
  .map((i) => i.name)
  .join(' ')
  .toLowerCase();
---

<a
  class="card"
  href={href(recipe.id)}
  data-recipe-card
  data-title={searchTitle}
  data-tags={searchTags}
  data-ingredients={searchIngredients}
  data-category={category}
>
  <div class="media">
    {
      image ? (
        <Image src={image} alt={title} widths={[320, 640]} sizes="(max-width: 640px) 100vw, 460px" />
      ) : (
        <div class="fallback" style={`background:linear-gradient(135deg, ${c1}, ${c2});`}>
          <span aria-hidden="true">🍽️</span>
        </div>
      )
    }
    <span class="scrim"></span>
    <h2 class="title">{title}</h2>
    <div class="meta">
      <span class="chip">
        <Icon name="lucide:users" size={16} />
        <span>{servings}</span>
      </span>
      <span class="chip">
        <Icon name="lucide:clock" size={16} />
        <span>{time}</span>
      </span>
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
  }
  .card[hidden] {
    display: none;
  }
  .media {
    position: relative;
    aspect-ratio: 3 / 2;
  }
  .media :global(img),
  .fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .fallback {
    display: grid;
    place-items: center;
    font-size: 3rem;
  }
  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0.1) 70%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }
  .title {
    position: absolute;
    top: 12px;
    left: 14px;
    right: 14px;
    margin: 0;
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.15;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
  }
  .meta {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    gap: 8px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .chip svg {
    opacity: 0.85;
  }
  .card:hover .title {
    text-decoration: none;
  }
  @media (hover: hover) {
    .card {
      transition: transform 0.15s ease;
    }
    .card:hover {
      transform: translateY(-2px);
    }
  }
</style>
