---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import RecipeMeta from '../../components/RecipeMeta.astro';
import IngredientList from '../../components/IngredientList.astro';
import MethodSteps from '../../components/MethodSteps.astro';
import ScaleControl from '../../components/ScaleControl.astro';
import CookMode from '../../components/CookMode.astro';
import LangToggle from '../../components/LangToggle.astro';
import { localeOf, recipeKeyOf } from '../../lib/recipes';
import { validateSteps } from '../../lib/references';
import { localeHref } from '../../lib/url';
import { t, format } from '../../i18n/ui';
import { LOCALES, type Locale } from '../../i18n/config';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { locale: localeOf(recipe.id), slug: recipeKeyOf(recipe.id) },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { data } = recipe;
const locale = localeOf(recipe.id) as Locale;
const key = recipeKeyOf(recipe.id);
const s = t(locale);
const { Content } = await render(recipe);

// Warn (at build time) about ingredient references that don't resolve.
const unmatched = validateSteps(data.method, data.ingredients);
if (unmatched.length > 0) {
  console.warn(
    `[recipes] ${recipe.id}: unmatched ingredient references: ${unmatched.join(', ')}`,
  );
}

const nutritionEntries = data.nutrition ? Object.entries(data.nutrition) : [];

const alternates = LOCALES.map((l) => ({
  locale: l,
  url: new URL(localeHref(l, key), Astro.site).href,
}));

// Payload for the client controller (scaling + popovers).
const clientData = {
  baseServings: data.servings,
  ingredients: Object.fromEntries(
    data.ingredients.map((i) => [i.name.toLowerCase(), i]),
  ),
  t: {
    servings: s.servings,
    select: s.select,
    stepOf: s.stepOf,
    next: s.next,
    done: s.done,
  },
};
---

<Base title={data.title} locale={locale} description={data.title} alternates={alternates}>
  <article>
    <div class="hero">
      {
        data.image ? (
          <Image src={data.image} alt={data.title} widths={[480, 960]} sizes="100vw" />
        ) : (
          <div class="hero-fallback"><span aria-hidden="true">🍽️</span></div>
        )
      }
      <a class="round back" href={localeHref(locale)} aria-label={s.backToRecipes}>
        <Icon name="lucide:chevron-left" size={24} />
      </a>
      <div class="hero-actions">
        <LangToggle locale={locale} path={key} variant="overlay" />
        <button class="round share" type="button" data-share aria-label={s.shareRecipe}>
          <Icon name="lucide:share" size={20} />
        </button>
      </div>
    </div>

    <div class="container">
      <div class="actions">
        <button class="start" type="button" data-cook-start>
          <Icon name="lucide:play" size={20} />
          {s.start}
        </button>
      </div>

      <h1>{data.title}</h1>

      <RecipeMeta
        servings={data.servings}
        prepTime={data.prepTime}
        cookTime={data.cookTime}
        locale={locale}
      />

      <section>
        <div class="section-head">
          <h2>{s.ingredients}</h2>
          <button class="scale-btn accent" type="button" data-scale-toggle>{s.scale}</button>
        </div>
        <ScaleControl ingredients={data.ingredients} servings={data.servings} locale={locale} />
        <IngredientList ingredients={data.ingredients} />
      </section>

      <section>
        <h2>{s.method}</h2>
        <MethodSteps method={data.method} />
      </section>

      {
        nutritionEntries.length > 0 && (
          <section>
            <h2>{s.nutrition}</h2>
            <p class="muted note">{format(s.nutritionNote, { n: data.servings })}</p>
            <ul class="nutrition">
              {nutritionEntries.map(([k, v]) => (
                <li>
                  <span class="muted">{k}</span>
                  <span>{v}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <section class="notes">
        <Content />
      </section>

      {data.sourceUrl && (
        <a class="source" href={data.sourceUrl} target="_blank" rel="noopener">
          {s.viewOriginalSource}
        </a>
      )}
    </div>

    <CookMode locale={locale} />
  </article>

  <script
    is:inline
    type="application/json"
    id="recipe-data"
    data-copied={s.linkCopied}
    set:html={JSON.stringify(clientData)}
  />
</Base>

<script>
  import '../../scripts/recipe-page.ts';

  document.querySelector('[data-share]')?.addEventListener('click', async () => {
    const shareData = { title: document.title, url: location.href };
    try {
      if (navigator.share) await navigator.share(shareData);
      else {
        await navigator.clipboard.writeText(location.href);
        const msg = document
          .getElementById('recipe-data')
          ?.getAttribute('data-copied');
        alert(msg || 'Link copied');
      }
    } catch {
      /* user cancelled — ignore */
    }
  });
</script>

<style>
  article {
    max-width: 760px;
    margin: 0 auto;
  }
  .hero {
    position: relative;
    width: 100%;
    height: clamp(220px, 40vh, 440px);
    overflow: hidden;
    border-radius: var(--radius-lg);
  }
  .hero :global(img),
  .hero-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-fallback {
    display: grid;
    place-items: center;
    font-size: 4rem;
    background: linear-gradient(135deg, #232526, #414345);
  }
  .round {
    position: absolute;
    top: 16px;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(6px);
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    line-height: 1;
  }
  .back {
    left: 16px;
  }
  .hero-actions {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .share {
    position: static;
    font-size: 1rem;
  }
  .actions {
    margin: 16px 0 8px;
    position: relative;
  }
  .start {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0;
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    background: var(--start);
    color: #062b12;
    font-size: 1.15rem;
    font-weight: 800;
    box-shadow: 0 8px 24px rgba(52, 199, 89, 0.35);
  }
  h2 {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 32px 0 12px;
  }
  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .scale-btn {
    border: 0;
    background: var(--surface);
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    font-weight: 700;
    font-size: 1rem;
  }
  .note {
    margin: 0 0 10px;
    font-size: 0.9rem;
  }
  .nutrition {
    list-style: none;
    margin: 0;
    padding: 8px 4px;
    background: var(--surface);
    border-radius: var(--radius);
  }
  .nutrition li {
    display: flex;
    justify-content: space-between;
    padding: 10px 14px;
  }
  .notes :global(p) {
    color: var(--muted);
  }
  .source {
    display: inline-block;
    margin-top: 24px;
    color: var(--accent);
    font-weight: 600;
  }
</style>
