---
// Root redirect shim (`/recipes/`). This is a static build, so language
// detection runs in the browser: saved preference -> browser language -> `en`.
// A <meta refresh> and manual links cover the no-JS case.
import { LOCALES, DEFAULT_LOCALE, LOCALE_LABELS } from '../i18n/config';
import { localeHref } from '../lib/url';

const targets = Object.fromEntries(LOCALES.map((l) => [l, localeHref(l)]));
const fallback = localeHref(DEFAULT_LOCALE);
---

<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rodrigo's Kitchen</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={fallback} />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <script is:inline define:vars={{ targets, fallback, defaultLocale: DEFAULT_LOCALE }}>
      (function () {
        try {
          var saved = localStorage.getItem('recipes:lang');
          var nav = (navigator.language || '').slice(0, 2).toLowerCase();
          var locale =
            saved && targets[saved]
              ? saved
              : targets[nav]
                ? nav
                : defaultLocale;
          location.replace(targets[locale] || fallback);
        } catch (e) {
          location.replace(fallback);
        }
      })();
    </script>
  </head>
  <body>
    <p>
      {LOCALES.map((l) => (
        <a href={targets[l]}>{LOCALE_LABELS[l]}</a>
      ))}
    </p>
  </body>
</html>
