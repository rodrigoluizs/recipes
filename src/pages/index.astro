---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import RecipeCard from '../components/RecipeCard.astro';
import {
  getAllRecipes,
  getCategories,
  categoryLabel,
} from '../lib/recipes';

const recipes = await getAllRecipes();
const categories = getCategories(recipes);
---

<Base title="All Recipes">
  <main class="container">
    <h1>All Recipes</h1>

    <div class="search">
      <Icon name="lucide:search" size={20} />
      <input
        id="search"
        type="search"
        placeholder="Recipes, Ingredients and More"
        aria-label="Search recipes"
        autocomplete="off"
      />
    </div>

    {
      categories.length > 1 && (
        <div class="chips" role="group" aria-label="Filter by category">
          <button class="pill is-active" data-category="" type="button">
            All
          </button>
          {categories.map((c) => (
            <button class="pill" data-category={c} type="button">
              {categoryLabel(c)}
            </button>
          ))}
        </div>
      )
    }

    <div class="grid" id="grid">
      {recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
    </div>

    <p class="empty" id="empty" hidden={recipes.length > 0}>
      {
        recipes.length === 0
          ? 'No recipes yet — add your first one.'
          : 'No recipes match your search.'
      }
    </p>
  </main>
</Base>

<style>
  .search {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 18px;
    height: 52px;
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--muted);
    margin-bottom: 20px;
  }
  .search input {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--fg);
    font-size: 1.05rem;
    outline: none;
  }
  .search input::placeholder {
    color: var(--muted);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 22px;
  }
  .pill {
    border: 0;
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--fg);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .pill.is-active {
    background: var(--accent);
    color: #fff;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap);
  }
  .empty {
    color: var(--muted);
    text-align: center;
    padding: 40px 0;
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const input = document.getElementById('search') as HTMLInputElement | null;
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-recipe-card]'),
  );
  const chips = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.pill'),
  );
  const empty = document.getElementById('empty');

  let query = '';
  let category = '';

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const haystack = [
        card.dataset.title,
        card.dataset.tags,
        card.dataset.ingredients,
      ].join(' ');
      const matchesQuery = !query || haystack.includes(query);
      const matchesCategory = !category || card.dataset.category === category;
      const show = matchesQuery && matchesCategory;
      card.hidden = !show;
      if (show) visible++;
    }
    if (empty) empty.hidden = visible !== 0;
  }

  input?.addEventListener('input', () => {
    query = input.value.trim().toLowerCase();
    apply();
  });

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      category = chip.dataset.category ?? '';
      for (const c of chips) c.classList.toggle('is-active', c === chip);
      apply();
    });
  }
</script>
