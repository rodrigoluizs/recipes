---
import '../styles/global.css';
import PullToRefresh from '../components/PullToRefresh.astro';

interface Props {
  title: string;
  description?: string;
}

const SITE_NAME = "Rodrigo's Kitchen";
const { title, description = 'A personal recipe collection.' } = Astro.props;
const asset = (path: string) =>
  `${import.meta.env.BASE_URL}/${path}`.replace(/\/{2,}/g, '/');
const favicon = asset('favicon.svg');
const manifest = asset('manifest.webmanifest');
const appleTouchIcon = asset('apple-touch-icon.png');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <title>{`${title} · ${SITE_NAME}`}</title>
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="manifest" href={manifest} />
    <link rel="apple-touch-icon" href={appleTouchIcon} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />
  </head>
  <body>
    <PullToRefresh />
    <slot />
  </body>
</html>
